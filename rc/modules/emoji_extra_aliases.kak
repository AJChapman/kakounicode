require-module kakounicode_ifte

declare-option -docstring 'Enable extra Emoji kakounicode aliases' \
    str kakounicode_enable_emoji_extra_aliases true

hook global ModuleLoaded kakounicode_db %{
    if %opt{kakounicode_enable_emoji_extra_aliases} %{ require-module kakounicode_emoji_extra_aliases }
}

provide-module kakounicode_emoji_extra_aliases %፠

echo -debug "loading kakounicode_emoji_extra_aliases"

# Putting these after certain emoji characters will change whether to display them as text-style or emoji-style
add-unicode '️' 'emoji_style' 'Combining emoji style'
add-unicode '︎' 'text_style' 'Combining text style'

# I don't know if it's the particular font I'm using, but these all seem to default to text style,
# so I've added these aliases with explicit emoji style

add-unicode '❤️' 'red_heart_emoji'                          'Red heart with emoji style'
add-unicode '❣️' 'heart_exclamation_emoji'                  'Heart exclamation emoji style'
add-unicode '☠️' 'skull_and_crossbones_emoji'               'Skull and crossbones emoji style'
