# Now some convenience aliases

add-unicode-alias '❤️' 'heart'
add-unicode-alias '❣️' 'heart!'
add-unicode-alias '☺️' 'smile'
add-unicode-alias '☺️' ':)'
add-unicode-alias '😀' ':D'
add-unicode-alias '🙃' '(:'
add-unicode-alias '☹️' 'frown'
add-unicode-alias '☹️' ':('
add-unicode-alias '🫤' ':/'

# Kaomoji

add-unicode '¯\_(ツ)_/¯'       'shrug'        'Shrug'
add-unicode '(╯°□°)╯︵ ┻━┻'    'table_flip'   'Table flip'
add-unicode '┬─┬ ノ( ゜-゜ノ)' 'table_unflip' 'Table unflip'
add-unicode 'ಠ_ಠ'              'side_eye'     'Side-eye'
add-unicode '(ᵔᴥᵔ)'            'cute_face'    'Cute face'
add-unicode 'ʕ- ᴥ- ʔ'          'bear'         'Bear'

፠
