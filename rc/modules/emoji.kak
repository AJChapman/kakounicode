require-module kakounicode_ifte

declare-option -docstring 'Enable Emoji kakounicode aliases' \
    str kakounicode_enable_emoji true

hook global ModuleLoaded kakounicode_db %{
    if %opt{kakounicode_enable_emoji} %{ require-module kakounicode_emoji }
}

provide-module kakounicode_emoji %፠

echo -debug "loading kakounicode_emoji"

